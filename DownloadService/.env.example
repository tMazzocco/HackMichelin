# DownloadService – environment variables
# Copy to .env for local dev: cp .env.example .env

# HTTP listener (host:port)
HTTP_ADDR=0.0.0.0:3001

# Absolute path to the media folder on disk
MEDIA_DIR=/media

# URL prefix used in HLS .m3u8 segment entries
FILES_BASE_URL=files

# Duration (seconds) per photo segment in the playlist
PHOTO_DURATION=5

# Default duration (seconds) per video segment when unknown
VIDEO_DURATION=10

# Log level: trace | debug | info | warn | error
RUST_LOG=info
