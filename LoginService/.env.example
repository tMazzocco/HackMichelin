# LoginService – environment variables
# Copy to .env for local dev: cp .env.example .env

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://admin:changeme@localhost:5432/hackmichelin

# HTTP listener (host:port)
HTTP_ADDR=0.0.0.0:3002

# JWT secret – change to a long random string in production
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Access token lifetime in seconds (default: 900 = 15 min)
JWT_EXPIRES_SECS=900

# Refresh token lifetime in days (default: 30)
REFRESH_EXPIRES_DAYS=30

# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=login-service

# Log level: trace | debug | info | warn | error
RUST_LOG=info
