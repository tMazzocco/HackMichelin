# StatsService – environment variables
# Copy to .env for local dev: cp .env.example .env

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://admin:changeme@localhost:5432/hackmichelin

# HTTP listener (host:port)
HTTP_ADDR=0.0.0.0:3010

# MQTT broker (StatsService subscribes to post.created / post.deleted)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=stats-service

# Log level: trace | debug | info | warn | error
RUST_LOG=info
