# PostService – environment variables
# Copy to .env for local dev: cp .env.example .env

# PostgreSQL connection string (required — used for media lookups)
DATABASE_URL=postgresql://admin:changeme@localhost:5432/hackmichelin

# HTTP listener (host:port)
HTTP_ADDR=0.0.0.0:3004

# Cassandra contact point
CASSANDRA_NODES=localhost:9042

# JWT secret (must match LoginService)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=post-service

# Log level: trace | debug | info | warn | error
RUST_LOG=info
