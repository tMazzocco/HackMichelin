# UploadService – environment variables
# Copy to .env for local dev: cp .env.example .env

# PostgreSQL connection string (required — stores media metadata)
DATABASE_URL=postgresql://admin:changeme@localhost:5432/hackmichelin

# HTTP listener (host:port)
HTTP_ADDR=0.0.0.0:3007

# JWT secret (must match LoginService)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Absolute path to the folder where uploaded files are saved
MEDIA_DIR=/media

# Maximum accepted upload size in bytes (default: 209715200 = 200 MB)
MAX_UPLOAD_BYTES=209715200

# URL prefix prepended to filenames to build the public download URL
DOWNLOAD_BASE_URL=/api/download/files

# Log level: trace | debug | info | warn | error
RUST_LOG=info
